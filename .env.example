# ─── Google Drive ────────────────────────────────────────────
# Caminho para o arquivo JSON da Service Account
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials.json

# ID da pasta do Google Drive a ser monitorada
# Você pode encontrá-lo na URL: drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_FOLDER_ID=your_folder_id_here

# ID da pasta de destino após processamento (ex: pasta "processado")
# Se não definido, o arquivo é apenas removido da pasta monitorada
GDRIVE_PROCESSED_FOLDER_ID=your_processed_folder_id_here

# Intervalo de polling em milissegundos (padrão: 60000 = 1 minuto)
POLL_INTERVAL_MS=60000

# ─── Paperless-NGX ───────────────────────────────────────────
# URL base da sua instância (sem barra no final)
PAPERLESS_URL=http://localhost:8000

# Token de API do Paperless-NGX
# Obtenha em: Configurações → API Token (ou via Django admin)
PAPERLESS_TOKEN=your_paperless_api_token

# Nome da tag de origem que será aplicada aos documentos
# A tag será criada automaticamente se não existir
PAPERLESS_TAG_NAME=google-drive

# ─── Telegram ────────────────────────────────────────────────
# Token do bot do Telegram
# Obtenha criando um bot via @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token

# ID do chat para onde as notificações serão enviadas
# Use @userinfobot para descobrir o seu chat ID
TELEGRAM_CHAT_ID=your_chat_id
